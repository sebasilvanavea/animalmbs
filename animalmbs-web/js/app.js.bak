// ---- Weight Views ----

function weightView(pet, weights) {
    const sorted = [...weights].sort((a, b) => new Date(a.date) - new Date(b.date));
    return `<div class="page-header">
            <a href="#/pets/${pet.id}" class="back-btn">← ${esc(pet.name)}</a>
            <h1>⚖️ Control de Peso</h1>
        </div>
        <div class="card">
            <div class="card-title">Evolución</div>
            <div class="chart-container">
                <canvas id="weight-chart"></canvas>
            </div>
        </div>
        <div class="card">
            <div class="card-title">Registrar Peso</div>
            <form data-action="create-weight">
                <input type="hidden" name="pet_id" value="${pet.id}">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Peso (kg) *</label>
                        <input type="number" name="weight" class="form-input" step="0.1" min="0" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Fecha *</label>
                        <input type="date" name="date" class="form-input" required value="${today()}">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <input type="text" name="notes" class="form-input" placeholder="Opcional">
                </div>
                <button type="submit" class="btn btn-primary btn-block">Registrar</button>
            </form>
        </div>
        ${sorted.length > 0 ? `<div class="card">
            <div class="card-title">Historial</div>
            ${sorted.reverse().map(w => `
                <div class="record-item">
                    <div class="record-header">
                        <span class="record-name">${w.weight} kg</span>
                        <span class="record-date">${fmtDate(w.date)}</span>
                    </div>
                    ${w.notes ? `<div class="record-detail">${esc(w.notes)}</div>` : ''}
                    <div class="record-actions">
                        <button class="btn btn-sm btn-danger" data-action="delete-weight" data-id="${w.id}">Eliminar</button>
                    </div>
                </div>
            `).join('')}
        </div>` : ''}`;
}

function renderWeightChart(weights) {
    const sorted = [...weights].sort((a, b) => new Date(a.date) - new Date(b.date));
    const canvas = document.getElementById('weight-chart');
    if (!canvas || sorted.length === 0) return;

    if (weightChart) weightChart.destroy();
    weightChart = new Chart(canvas, {
        type: 'line',
        data: {
            labels: sorted.map(w => fmtDate(w.date)),
            datasets: [{
                label: 'Peso (kg)',
                data: sorted.map(w => w.weight),
                borderColor: '#5cb8a2',
                backgroundColor: 'rgba(92,184,162,0.1)',
                fill: true, tension: 0.3, pointRadius: 5,
                pointBackgroundColor: '#5cb8a2',
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: false, grid: { color: 'rgba(0,0,0,0.05)' } },
                x: { grid: { display: false } }
            }
        }
    });
}

