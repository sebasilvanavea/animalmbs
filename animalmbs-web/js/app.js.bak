// ---- Empty State ----

function emptyState(emoji, title, subtitle) {
    return `<div class="empty-state">
        <div class="emoji">${emoji}</div>
        <h3>${title}</h3>
        <p>${subtitle}</p>
    </div>`;
}

// ---- Public Ficha (from QR ?d= parameter) ----

function renderPublicFicha(encoded) {
    try {
        let b64 = encoded.replace(/-/g, '+').replace(/_/g, '/');
        while (b64.length % 4) b64 += '=';
        const json = decodeURIComponent(escape(atob(b64)));
        const data = JSON.parse(json);
        if (!data.pet) throw new Error('Invalid data');
        render(publicFichaView(data));
    } catch (e) {
        render(emptyState('🐾', 'AnimalMbs', 'El enlace no es válido o ha expirado.'));
    }
}

function publicFichaView(data) {
    const pet = data.pet;
    const emoji = SPECIES[pet.species] || '🐾';
    const apTypes = { Interno: 'Interno', Externo: 'Externo', Ambos: 'Ambos' };

    let html = `<div class="ficha-header">
            <div class="logo">🐾 ANIMALMBS</div>
            <div class="ficha-avatar">${emoji}</div>
            <h1>${esc(pet.name)}</h1>
            <div class="subtitle">Ficha Clínica Veterinaria</div>
        </div>
        <div class="ficha-container">
            <div class="card">
                <div class="card-title">Datos del Paciente</div>
                <div class="info-grid">
                    <div class="info-item"><span class="info-label">Especie</span><span class="info-value">${emoji} ${esc(pet.species)}</span></div>
                    <div class="info-item"><span class="info-label">Raza</span><span class="info-value">${esc(pet.breed) || 'N/E'}</span></div>
                    <div class="info-item"><span class="info-label">Sexo</span><span class="info-value">${esc(pet.sex)}</span></div>
                    <div class="info-item"><span class="info-label">Edad</span><span class="info-value">${esc(pet.age) || 'N/E'}</span></div>
                    <div class="info-item"><span class="info-label">Peso</span><span class="info-value">${pet.weight > 0 ? pet.weight + ' kg' : 'N/R'}</span></div>
                    <div class="info-item"><span class="info-label">Color</span><span class="info-value">${esc(pet.color) || 'N/E'}</span></div>
                    ${pet.microchip ? `<div class="info-item info-full"><span class="info-label">Microchip</span><span class="info-value">${esc(pet.microchip)}</span></div>` : ''}
                </div>
            </div>`;

    if (data.vac?.length) {
        html += `<div class="card"><div class="card-title">Vacunas</div>`;
        for (const v of data.vac) {
            html += `<div class="record-item">
                <div class="record-header"><span class="record-name"><span class="badge badge-green">💉</span> ${esc(v.n)}</span><span class="record-date">${esc(v.d)}</span></div>
                ${v.l ? `<div class="record-detail">Lote: ${esc(v.l)}</div>` : ''}
                ${v.nx ? `<div class="record-next">📅 Próxima dosis: ${esc(v.nx)}</div>` : ''}
            </div>`;
        }
        html += `</div>`;
    }

    if (data.ap?.length) {
        html += `<div class="card"><div class="card-title">Antiparasitarios</div>`;
        for (const a of data.ap) {
            html += `<div class="record-item">
                <div class="record-header"><span class="record-name"><span class="badge badge-orange">🛡️</span> ${esc(a.n)}</span><span class="record-date">${esc(a.d)}</span></div>
                <div class="record-detail">Tipo: ${esc(apTypes[a.t] || a.t)}</div>
                ${a.nx ? `<div class="record-next">📅 Próxima aplicación: ${esc(a.nx)}</div>` : ''}
            </div>`;
        }
        html += `</div>`;
    }

    if (data.med?.length) {
        html += `<div class="card"><div class="card-title">Historial Médico</div>`;
        for (const r of data.med) {
            html += `<div class="record-item">
                <div class="record-header"><span class="record-name"><span class="badge badge-purple">📋</span> ${esc(r.r)}</span><span class="record-date">${esc(r.d)}</span></div>
                ${r.dx ? `<div class="record-detail"><strong>Diagnóstico:</strong> ${esc(r.dx)}</div>` : ''}
                ${r.tx ? `<div class="record-detail"><strong>Tratamiento:</strong> ${esc(r.tx)}</div>` : ''}
            </div>`;
        }
        html += `</div>`;
    }

    html += `<div class="card" style="padding:1rem;">
            <button class="btn btn-primary btn-block" data-action="print">🖨️ Imprimir / Guardar PDF</button>
        </div>
    </div>
    <div class="ficha-footer">
        <p>Generado el ${esc(data.gen || '')} por <strong>AnimalMbs</strong></p>
        <p style="margin-top:0.25rem;">Ficha clínica veterinaria digital</p>
    </div>`;

    return html;
}

// ---- Init ----

async function init() {
    // Check for public ficha URL
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.has('d')) {
        renderPublicFicha(urlParams.get('d'));
        return;
    }

    // Check auth state
    const { data: { session } } = await auth.getSession();
    if (session) {
        currentUser = session.user;
    }

    auth.onAuthChange((_event, session) => {
        currentUser = session?.user || null;
        handleRoute();
    });

    window.addEventListener('hashchange', handleRoute);
    handleRoute();
}

init();
