// ============================================================
// AnimalMbs Web — Main Application
// Router, Views, Event Handlers
// ============================================================

import { auth, pets, vaccines, antiparasitics, medicalRecords, weightEntries, getFullPetData } from './api.js';

// ---- Constants ----

const SPECIES = {
    Perro: '🐕', Gato: '🐈', Ave: '🐦', Conejo: '🐇',
    'Hámster': '🐹', Reptil: '🦎', Otro: '🐾'
};
const SPECIES_LIST = ['Perro', 'Gato', 'Ave', 'Conejo', 'Hámster', 'Reptil', 'Otro'];
const SEX_LIST = ['Macho', 'Hembra', 'Desconocido'];
const AP_TYPES = ['Interno', 'Externo', 'Ambos'];

let currentUser = null;
let weightChart = null;
const $app = document.getElementById('app');

// ---- Utilities ----

const esc = (s) => {
    if (!s) return '';
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
};
const fmtDate = (d) => d ? new Date(d + 'T00:00:00').toLocaleDateString('es-CL', { day: '2-digit', month: 'short', year: 'numeric' }) : '';
const today = () => new Date().toISOString().split('T')[0];
const age = (birthDate) => {
    if (!birthDate) return 'Sin datos';
    const bd = new Date(birthDate + 'T00:00:00');
    const now = new Date();
    const years = now.getFullYear() - bd.getFullYear();
    const months = now.getMonth() - bd.getMonth() + (years * 12);
    if (months >= 12) { const y = Math.floor(months / 12); return `${y} año${y === 1 ? '' : 's'}`; }
    return `${months} mes${months === 1 ? '' : 'es'}`;
};

function toast(msg) {
    let t = document.querySelector('.toast');
    if (!t) { t = document.createElement('div'); t.className = 'toast'; document.body.appendChild(t); }
    t.textContent = msg;
    t.classList.add('visible');
    setTimeout(() => t.classList.remove('visible'), 2500);
}

function navigate(route) { window.location.hash = '#/' + route; }

// ---- Event Delegation ----

$app.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;
    const action = btn.dataset.action;
    const id = btn.dataset.id;

    if (action === 'logout') { await auth.signOut(); navigate('login'); }
    if (action === 'delete-pet') { showConfirm('¿Eliminar mascota?', 'Se borrarán todos sus registros.', () => deletePet(id)); }
    if (action === 'delete-vaccine') { showConfirm('¿Eliminar vacuna?', '', () => deleteRecord('vaccines', id, btn)); }
    if (action === 'delete-antiparasitic') { showConfirm('¿Eliminar antiparasitario?', '', () => deleteRecord('antiparasitics', id, btn)); }
    if (action === 'delete-medical') { showConfirm('¿Eliminar registro médico?', '', () => deleteRecord('medical_records', id, btn)); }
    if (action === 'delete-weight') { showConfirm('¿Eliminar registro?', '', () => deleteRecord('weight_entries', id, btn)); }
    if (action === 'print') { window.print(); }
    if (action === 'generate-qr') { generateQR(id); }
    if (action === 'confirm-yes') { const fn = window._confirmCallback; if (fn) fn(); closeConfirm(); }
    if (action === 'confirm-no') { closeConfirm(); }
});

$app.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const action = form.dataset.action;
    if (!action) return;

    const fd = new FormData(form);
    const data = Object.fromEntries(fd.entries());
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Guardando...'; }

    try {
        if (action === 'login') { await handleLogin(data); }
        else if (action === 'register') { await handleRegister(data); }
        else if (action === 'create-pet') { await handleCreatePet(data); }
        else if (action === 'edit-pet') { await handleEditPet(data); }
        else if (action === 'create-vaccine') { await handleCreateVaccine(data); }
        else if (action === 'create-antiparasitic') { await handleCreateAntiparasitic(data); }
        else if (action === 'create-medical') { await handleCreateMedical(data); }
        else if (action === 'create-weight') { await handleCreateWeight(data); }
    } catch (err) {
        toast('Error: ' + err.message);
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Guardar'; }
    }
});

// ---- Confirm Dialog ----

function showConfirm(title, msg, callback) {
    window._confirmCallback = callback;
    const overlay = document.createElement('div');
    overlay.className = 'dialog-overlay';
    overlay.id = 'confirm-dialog';
    overlay.innerHTML = `<div class="dialog-box">
        <h3>${esc(title)}</h3>
        ${msg ? `<p>${esc(msg)}</p>` : '<p>Esta acción no se puede deshacer.</p>'}
        <div class="dialog-actions">
            <button class="btn btn-outline" data-action="confirm-no">Cancelar</button>
            <button class="btn btn-danger" data-action="confirm-yes">Eliminar</button>
        </div>
    </div>`;
    $app.appendChild(overlay);
}
function closeConfirm() {
    document.getElementById('confirm-dialog')?.remove();
    window._confirmCallback = null;
}

// ---- Form Handlers ----

async function handleLogin({ email, password }) {
    const { error } = await auth.signIn(email, password);
    if (error) throw error;
    navigate('');
}

async function handleRegister({ email, password, password2 }) {
    if (password !== password2) throw new Error('Las contraseñas no coinciden');
    if (password.length < 6) throw new Error('La contraseña debe tener al menos 6 caracteres');
    const { error } = await auth.signUp(email, password);
    if (error) throw error;
    toast('¡Cuenta creada! Revisa tu correo para confirmar.');
    navigate('login');
}

async function handleCreatePet(data) {
    const pet = {
        name: data.name, species: data.species, breed: data.breed,
        birth_date: data.birth_date || null, sex: data.sex,
        color: data.color, weight: parseFloat(data.weight) || 0,
        microchip_number: data.microchip_number, notes: data.notes,
    };
    const created = await pets.create(pet);
    toast('Mascota agregada');
    navigate(`pets/${created.id}`);
}

async function handleEditPet(data) {
    const updates = {
        name: data.name, species: data.species, breed: data.breed,
        birth_date: data.birth_date || null, sex: data.sex,
        color: data.color, weight: parseFloat(data.weight) || 0,
        microchip_number: data.microchip_number, notes: data.notes,
    };
    await pets.update(data.id, updates);
    toast('Mascota actualizada');
    navigate(`pets/${data.id}`);
}

async function handleCreateVaccine(data) {
    await vaccines.create({
        pet_id: data.pet_id, name: data.name, date: data.date,
        next_dose_date: data.next_dose_date || null,
        lot_number: data.lot_number, veterinarian: data.veterinarian, notes: data.notes,
    });
    toast('Vacuna registrada');
    navigate(`pets/${data.pet_id}/vaccines`);
}

async function handleCreateAntiparasitic(data) {
    await antiparasitics.create({
        pet_id: data.pet_id, product_name: data.product_name, type: data.type, date: data.date,
        next_application_date: data.next_application_date || null, notes: data.notes,
    });
    toast('Antiparasitario registrado');
    navigate(`pets/${data.pet_id}/antiparasitics`);
}

async function handleCreateMedical(data) {
    await medicalRecords.create({
        pet_id: data.pet_id, date: data.date, reason: data.reason,
        diagnosis: data.diagnosis, treatment: data.treatment,
        veterinarian: data.veterinarian, notes: data.notes,
    });
    toast('Registro médico guardado');
    navigate(`pets/${data.pet_id}/medical`);
}

async function handleCreateWeight(data) {
    await weightEntries.create({
        pet_id: data.pet_id, date: data.date, weight: parseFloat(data.weight),
        notes: data.notes,
    });
    // Also update pet's current weight
    await pets.update(data.pet_id, { weight: parseFloat(data.weight) });
    toast('Peso registrado');
    navigate(`pets/${data.pet_id}/weight`);
}

async function deletePet(id) {
    await pets.delete(id);
    toast('Mascota eliminada');
    navigate('');
}

async function deleteRecord(table, id, btn) {
    const api = { vaccines, antiparasitics, medical_records: medicalRecords, weight_entries: weightEntries };
    await api[table].delete(id);
    btn.closest('.record-item')?.remove();
    toast('Eliminado');
}

// ---- QR Generation ----

async function generateQR(petId) {
    const full = await getFullPetData(petId);
    const qrData = buildQRPayload(full);
    const url = `${window.location.origin}?d=${qrData}`;
    const canvas = document.getElementById('qr-canvas');
    if (canvas) {
        await window.QRCode.toCanvas(canvas, url, { width: 250, margin: 2 });
        document.getElementById('qr-url')?.setAttribute('href', url);
    }
}

function buildQRPayload(full) {
    const { pet, vaccines: vacs, antiparasitics: aps, medicalRecords: recs } = full;
    const data = {
        app: 'AnimalMbs', v: 1,
        pet: {
            name: pet.name, species: pet.species, breed: pet.breed,
            sex: pet.sex, age: age(pet.birth_date),
            weight: pet.weight, microchip: pet.microchip_number, color: pet.color,
        },
    };
    if (vacs.length) {
        data.vac = vacs.slice(0, 5).map(v => {
            const e = { n: v.name, d: fmtDate(v.date) };
            if (v.next_dose_date) e.nx = fmtDate(v.next_dose_date);
            if (v.lot_number) e.l = v.lot_number;
            return e;
        });
    }
    if (aps.length) {
        data.ap = aps.slice(0, 3).map(a => {
            const e = { n: a.product_name, t: a.type, d: fmtDate(a.date) };
            if (a.next_application_date) e.nx = fmtDate(a.next_application_date);
            return e;
        });
    }
    if (recs.length) {
        data.med = recs.slice(0, 3).map(r => {
            const e = { r: r.reason, d: fmtDate(r.date) };
            if (r.diagnosis) e.dx = r.diagnosis;
            if (r.treatment) e.tx = r.treatment;
            return e;
        });
    }
    data.gen = fmtDate(today());
    const json = JSON.stringify(data);
    let b64 = btoa(unescape(encodeURIComponent(json)));
    b64 = b64.replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
    return b64;
}

// ---- Router ----

async function handleRoute() {
    const hash = window.location.hash || '#/';
    const parts = hash.replace('#/', '').split('/').filter(Boolean);

    // Public ficha from QR
    const urlP = new URLSearchParams(window.location.search);
    if (urlP.has('d')) { renderPublicFicha(urlP.get('d')); return; }

    // Auth check
    if (!currentUser) {
        if (parts[0] === 'register') { render(registerView()); return; }
        render(loginView()); return;
    }

    try {
        if (parts.length === 0) {
            const list = await pets.list();
            render(appShell(petListView(list), 'pets'));
        } else if (parts[0] === 'pets' && parts[1] === 'new') {
            render(appShell(petFormView()));
        } else if (parts[0] === 'pets' && parts.length === 2) {
            const full = await getFullPetData(parts[1]);
            render(appShell(petDetailView(full)));
        } else if (parts[0] === 'pets' && parts[2] === 'edit') {
            const pet = await pets.get(parts[1]);
            render(appShell(petFormView(pet)));
        } else if (parts[0] === 'pets' && parts[2] === 'vaccines' && parts[3] === 'new') {
            const pet = await pets.get(parts[1]);
            render(appShell(vaccineFormView(pet)));
        } else if (parts[0] === 'pets' && parts[2] === 'vaccines') {
            const [pet, vacs] = await Promise.all([pets.get(parts[1]), vaccines.list(parts[1])]);
            render(appShell(vaccineListView(pet, vacs)));
        } else if (parts[0] === 'pets' && parts[2] === 'antiparasitics' && parts[3] === 'new') {
            const pet = await pets.get(parts[1]);
            render(appShell(antiparasiticFormView(pet)));
        } else if (parts[0] === 'pets' && parts[2] === 'antiparasitics') {
            const [pet, aps] = await Promise.all([pets.get(parts[1]), antiparasitics.list(parts[1])]);
            render(appShell(antiparasiticListView(pet, aps)));
        } else if (parts[0] === 'pets' && parts[2] === 'medical' && parts[3] === 'new') {
            const pet = await pets.get(parts[1]);
            render(appShell(medicalFormView(pet)));
        } else if (parts[0] === 'pets' && parts[2] === 'medical') {
            const [pet, recs] = await Promise.all([pets.get(parts[1]), medicalRecords.list(parts[1])]);
            render(appShell(medicalListView(pet, recs)));
        } else if (parts[0] === 'pets' && parts[2] === 'weight') {
            const [pet, ws] = await Promise.all([pets.get(parts[1]), weightEntries.list(parts[1])]);
            render(appShell(weightView(pet, ws)));
            renderWeightChart(ws);
        } else if (parts[0] === 'pets' && parts[2] === 'qr') {
            const full = await getFullPetData(parts[1]);
            render(appShell(qrView(full)));
            generateQR(parts[1]);
        } else if (parts[0] === 'settings') {
            render(appShell(settingsView(), 'settings'));
        } else {
            navigate('');
        }
    } catch (err) {
        console.error(err);
        toast('Error al cargar: ' + err.message);
    }
}

function render(html) {
    $app.innerHTML = html;
}

// ---- Views ----

function appShell(content, activeTab = '') {
    return `<div class="app-shell">
        <div class="top-bar">
            <div class="logo">🐾 AnimalMbs</div>
            <div class="user-menu">
                <span class="text-sm text-secondary">${esc(currentUser?.email?.split('@')[0])}</span>
                <button class="btn btn-sm btn-outline" data-action="logout">Salir</button>
            </div>
        </div>
        <div class="main-content">${content}</div>
        <div class="bottom-nav">
            <a href="#/" class="${activeTab === 'pets' ? 'active' : ''}">
                <span class="nav-icon">🐾</span> Mascotas
            </a>
            <a href="#/settings" class="${activeTab === 'settings' ? 'active' : ''}">
                <span class="nav-icon">⚙️</span> Ajustes
            </a>
        </div>
    </div>`;
}

function loginView() {
    return `<div class="auth-container">
        <div class="auth-box">
            <div class="auth-logo">
                <div class="emoji">🐾</div>
                <h1>AnimalMbs</h1>
                <p>Gestión veterinaria digital</p>
            </div>
            <div class="auth-error" id="auth-error"></div>
            <form data-action="login">
                <div class="form-group">
                    <label class="form-label">Correo electrónico</label>
                    <input type="email" name="email" class="form-input" required autocomplete="email" placeholder="tu@correo.com">
                </div>
                <div class="form-group">
                    <label class="form-label">Contraseña</label>
                    <input type="password" name="password" class="form-input" required autocomplete="current-password" placeholder="••••••••">
                </div>
                <button type="submit" class="btn btn-primary btn-block">Iniciar Sesión</button>
            </form>
            <div class="auth-footer">
                ¿No tienes cuenta? <a href="#/register">Crear cuenta</a>
            </div>
        </div>
    </div>`;
}

function registerView() {
    return `<div class="auth-container">
        <div class="auth-box">
            <div class="auth-logo">
                <div class="emoji">🐾</div>
                <h1>Crear Cuenta</h1>
                <p>Únete a AnimalMbs</p>
            </div>
            <div class="auth-error" id="auth-error"></div>
            <form data-action="register">
                <div class="form-group">
                    <label class="form-label">Correo electrónico</label>
                    <input type="email" name="email" class="form-input" required placeholder="tu@correo.com">
                </div>
                <div class="form-group">
                    <label class="form-label">Contraseña</label>
                    <input type="password" name="password" class="form-input" required minlength="6" placeholder="Mínimo 6 caracteres">
                </div>
                <div class="form-group">
                    <label class="form-label">Confirmar contraseña</label>
                    <input type="password" name="password2" class="form-input" required minlength="6" placeholder="Repite tu contraseña">
                </div>
                <button type="submit" class="btn btn-primary btn-block">Crear Cuenta</button>
            </form>
            <div class="auth-footer">
                ¿Ya tienes cuenta? <a href="#/login">Iniciar sesión</a>
            </div>
        </div>
    </div>`;
}

function petListView(list) {
    return `<div class="page-header">
            <h1>Mis Mascotas</h1>
        </div>
        <div class="pet-grid">
            ${list.map(p => `
                <a href="#/pets/${p.id}" class="pet-card">
                    <div class="emoji">${SPECIES[p.species] || '🐾'}</div>
                    <div class="pet-name">${esc(p.name)}</div>
                    <div class="pet-info">${esc(p.species)}${p.breed ? ' · ' + esc(p.breed) : ''}</div>
                    ${p.weight > 0 ? `<div class="pet-weight">${p.weight} kg</div>` : ''}
                </a>
            `).join('')}
            <a href="#/pets/new" class="add-pet-card">
                <span class="plus">+</span>
                <span>Agregar Mascota</span>
            </a>
        </div>`;
}

function petDetailView({ pet, vaccines: vacs, antiparasitics: aps, medicalRecords: recs, weights }) {
    const emoji = SPECIES[pet.species] || '🐾';
    const nextVac = vacs.find(v => v.next_dose_date && new Date(v.next_dose_date) > new Date());
    const nextAp = aps.find(a => a.next_application_date && new Date(a.next_application_date) > new Date());

    return `<div class="page-header">
            <a href="#/" class="back-btn">← Mascotas</a>
        </div>
        <div class="pet-hero">
            <div class="emoji">${emoji}</div>
            <h2>${esc(pet.name)}</h2>
            <div class="subtitle">${esc(pet.species)}${pet.breed ? ' · ' + esc(pet.breed) : ''}</div>
        </div>

        <div class="card">
            <div class="card-title">Información</div>
            <div class="info-grid">
                <div class="info-item"><span class="info-label">Sexo</span><span class="info-value">${esc(pet.sex)}</span></div>
                <div class="info-item"><span class="info-label">Edad</span><span class="info-value">${age(pet.birth_date)}</span></div>
                <div class="info-item"><span class="info-label">Peso</span><span class="info-value">${pet.weight > 0 ? pet.weight + ' kg' : 'N/R'}</span></div>
                <div class="info-item"><span class="info-label">Color</span><span class="info-value">${esc(pet.color) || 'N/E'}</span></div>
                ${pet.microchip_number ? `<div class="info-item info-full"><span class="info-label">Microchip</span><span class="info-value">${esc(pet.microchip_number)}</span></div>` : ''}
            </div>
        </div>

        <div class="quick-actions">
            <a href="#/pets/${pet.id}/vaccines" class="quick-action qa-green">
                <span class="qa-icon">💉</span>Vacunas
                <span class="badge badge-green">${vacs.length}</span>
            </a>
            <a href="#/pets/${pet.id}/antiparasitics" class="quick-action qa-orange">
                <span class="qa-icon">🛡️</span>Antipar.
                <span class="badge badge-orange">${aps.length}</span>
            </a>
            <a href="#/pets/${pet.id}/medical" class="quick-action qa-purple">
                <span class="qa-icon">📋</span>Historial
                <span class="badge badge-purple">${recs.length}</span>
            </a>
            <a href="#/pets/${pet.id}/weight" class="quick-action qa-blue">
                <span class="qa-icon">⚖️</span>Peso
                <span class="badge badge-blue">${weights.length}</span>
            </a>
            <a href="#/pets/${pet.id}/qr" class="quick-action qa-green">
                <span class="qa-icon">📱</span>QR
            </a>
            <a href="#/pets/${pet.id}/edit" class="quick-action qa-pink">
                <span class="qa-icon">✏️</span>Editar
            </a>
        </div>

        ${nextVac ? `<div class="card"><div class="flex-between">
            <span>📅 Próxima vacuna: <strong>${esc(nextVac.name)}</strong></span>
            <span class="badge badge-green">${fmtDate(nextVac.next_dose_date)}</span>
        </div></div>` : ''}
        ${nextAp ? `<div class="card"><div class="flex-between">
            <span>📅 Próximo antiparasitario: <strong>${esc(nextAp.product_name)}</strong></span>
            <span class="badge badge-orange">${fmtDate(nextAp.next_application_date)}</span>
        </div></div>` : ''}

        ${pet.notes ? `<div class="card"><div class="card-title">Notas</div><p class="text-secondary">${esc(pet.notes)}</p></div>` : ''}

        <button class="btn btn-danger btn-block mt-3" data-action="delete-pet" data-id="${pet.id}">
            Eliminar Mascota
        </button>`;
}

function petFormView(pet = null) {
    const isEdit = !!pet;
    return `<div class="page-header">
            <a href="#/${isEdit ? 'pets/' + pet.id : ''}" class="back-btn">← ${isEdit ? pet.name : 'Mascotas'}</a>
            <h1>${isEdit ? 'Editar Mascota' : 'Nueva Mascota'}</h1>
        </div>
        <div class="card">
            <form data-action="${isEdit ? 'edit-pet' : 'create-pet'}">
                ${isEdit ? `<input type="hidden" name="id" value="${pet.id}">` : ''}
                <div class="form-group">
                    <label class="form-label">Nombre *</label>
                    <input type="text" name="name" class="form-input" required value="${esc(pet?.name || '')}">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Especie</label>
                        <select name="species" class="form-select">
                            ${SPECIES_LIST.map(s => `<option value="${s}" ${pet?.species === s ? 'selected' : ''}>${SPECIES[s]} ${s}</option>`).join('')}
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Sexo</label>
                        <select name="sex" class="form-select">
                            ${SEX_LIST.map(s => `<option value="${s}" ${pet?.sex === s ? 'selected' : ''}>${s}</option>`).join('')}
                        </select>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Raza</label>
                    <input type="text" name="breed" class="form-input" value="${esc(pet?.breed || '')}">
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Fecha de nacimiento</label>
                        <input type="date" name="birth_date" class="form-input" value="${pet?.birth_date || ''}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Peso (kg)</label>
                        <input type="number" name="weight" class="form-input" step="0.1" min="0" value="${pet?.weight || ''}">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Color</label>
                        <input type="text" name="color" class="form-input" value="${esc(pet?.color || '')}">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Microchip</label>
                        <input type="text" name="microchip_number" class="form-input" value="${esc(pet?.microchip_number || '')}">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Notas</label>
                    <textarea name="notes" class="form-textarea">${esc(pet?.notes || '')}</textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-block">${isEdit ? 'Guardar Cambios' : 'Agregar Mascota'}</button>
            </form>
        </div>`;
}

